{
  "info": {
    "name": "XOC API AWS",
    "description": "Postman collection for the multi-stack XOC AWS API. Uses clean routes without /api.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "4f6e8b75-d8bf-4a10-9547-4c8d5cfdbf34"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://replace-me.execute-api.us-east-1.amazonaws.com" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "tenantId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "sessionId", "value": "" },
    { "key": "chatThreadId", "value": "" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "ChangeMe123!" },
    { "key": "tenantName", "value": "XOC Demo Tenant" },
    { "key": "runtimeBaseUrl", "value": "https://replace-me-azure-function.azurewebsites.net" },
    { "key": "agentKeyId", "value": "1" },
    { "key": "ticketId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /onboarding/tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{tenantName}}\",\n  \"admin_email\": \"{{adminEmail}}\",\n  \"admin_password\": \"{{adminPassword}}\",\n  \"admin_username\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/onboarding/tenant",
              "host": ["{{baseUrl}}"],
              "path": ["onboarding", "tenant"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('onboarding success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 409]); });",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "  if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "  if (json.tenant && json.tenant.id) pm.collectionVariables.set('tenantId', String(json.tenant.id));",
                  "  if (json.owner_user && json.owner_user.id) pm.collectionVariables.set('userId', String(json.owner_user.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "if (json.user && json.user.tenant_id) pm.collectionVariables.set('tenantId', String(json.user.tenant_id));",
                  "if (json.user && json.user.id) pm.collectionVariables.set('userId', String(json.user.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
      ]
    },
