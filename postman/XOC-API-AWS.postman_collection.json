                  "pm.test('chat request completed', function () { pm.expect(pm.response.code).to.be.oneOf([200, 500]); });",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json.session_id) pm.collectionVariables.set('sessionId', String(json.session_id));",
                  "  if (json.thread_id) pm.collectionVariables.set('chatThreadId', String(json.thread_id));",
                  "} catch (e) {}"
