{
  "info": {
    "name": "XOC API AWS",
    "description": "Postman collection for the FastAPI + API Gateway deployment. Set `baseUrl` to your API Gateway URL, then run onboarding/login to populate tokens automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "4f6e8b75-d8bf-4a10-9547-4c8d5cfdbf34"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://replace-me.execute-api.us-east-1.amazonaws.com" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "companyId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "sessionId", "value": "" },
    { "key": "chatThreadId", "value": "" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "ChangeMe123!" },
    { "key": "companyName", "value": "XOC Demo Tenant" },
    { "key": "runtimeBaseUrl", "value": "https://replace-me-azure-function.azurewebsites.net" },
    { "key": "agentKeyId", "value": "1" },
    { "key": "ticketId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/onboarding/tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"{{companyName}}\",\n  \"admin_email\": \"{{adminEmail}}\",\n  \"admin_password\": \"{{adminPassword}}\",\n  \"admin_username\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/tenant",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "tenant"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('onboarding success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 409]); });",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "  if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "  if (json.company && json.company.id) pm.collectionVariables.set('companyId', String(json.company.id));",
                  "  if (json.owner_user && json.owner_user.id) pm.collectionVariables.set('userId', String(json.owner_user.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "if (json.user && json.user.company_id) pm.collectionVariables.set('companyId', String(json.user.company_id));",
                  "if (json.user && json.user.id) pm.collectionVariables.set('userId', String(json.user.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refreshToken', json.refresh_token);"
                ]
              }
            }
          ]
        }
      ]
    },
