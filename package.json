{
  "name": "xoc-api-aws",
  "version": "0.1.0",
  "private": true,
  "description": "XOC core API on AWS Serverless Framework",
  "scripts": {
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage prod",
    "deploy:shared:dev": "serverless deploy --stage dev --config serverless.shared.js",
    "deploy:tickets:dev": "serverless deploy --stage dev --config serverless.tickets.js",
    "deploy:auth:dev": "serverless deploy --stage dev --config serverless.auth.js",
    "deploy:chat:dev": "serverless deploy --stage dev --config serverless.chat.js",
    "deploy:ops:dev": "serverless deploy --stage dev --config serverless.ops.js",
    "deploy:tenant:dev": "serverless deploy --stage dev --config serverless.tenant.js",
    "deploy:admin:dev": "serverless deploy --stage dev --config serverless.admin.js",
    "package:dev": "serverless package --stage dev",
    "logs:api:dev": "serverless logs --function apiHttp --stage dev",
    "invoke:api:local": "serverless invoke local --function apiHttp",
    "dev": "uvicorn src.handlers.api:app --reload --host 0.0.0.0 --port 8000"
  },
  "devDependencies": {
    "serverless": "^4.18.2"
  }
}
